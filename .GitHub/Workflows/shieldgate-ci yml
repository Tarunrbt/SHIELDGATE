name: ShieldGate CI/CD

on:
  push:
    branches:
      - main
      - staging

  pull_request:
    branches:
      - main

env:
  NODE_VERSION: 20

jobs:

  lint:
    name: Code Quality Check
    runs-on: ubuntu-latest

  frontend-build:
    name: Frontend Build
    runs-on: ubuntu-latest
    needs: lint

  frontend-security:
    name: Frontend Dependency Audit
    runs-on: ubuntu-latest
    needs: frontend-build

  backend-build:
    name: Backend Build
    runs-on: ubuntu-latest
    needs: lint

  backend-security:
    name: Backend Security Scan
    runs-on: ubuntu-latest
    needs: backend-build

  unit-tests:
    name: Unit Tests
    runs-on: ubuntu-latest
    needs:
      - frontend-build
      - backend-build

  integration-tests:
    name: Integration Tests
    runs-on: ubuntu-latest
    needs: unit-tests

  docker-build:
    name: Docker Image Validation
    runs-on: ubuntu-latest
    needs: integration-tests

  deploy-frontend:
    name: Deploy Frontend
    runs-on: ubuntu-latest
    needs: docker-build
    if: github.ref == 'refs/heads/main'

  deploy-backend:
    name: Deploy Backend
    runs-on: ubuntu-latest
    needs: docker-build
    if: github.ref == 'refs/heads/main'

  post-deployment-healthcheck:
    name: Production Health Check
    runs-on: ubuntu-latest
    needs:
      - deploy-frontend
      - deploy-backend

  notify:
    name: Deployment Notification
    runs-on: ubuntu-latest
    needs: post-deployment-healthcheck
